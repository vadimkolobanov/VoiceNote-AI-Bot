# Mobile env. Скопируй в `assets/.env` (в .gitignore).
#
# Адрес backend:
# - Android emulator        → http://10.0.2.2:8765 (10.0.2.2 = host machine)
# - iOS simulator / desktop → http://localhost:8765
# - Физическое устройство   → http://<твой-LAN-IP>:8765 (например 192.168.0.10)
# - Прод                    → https://api.voicenote.example.com
API_BASE_URL=http://10.0.2.2:8765
API_VERSION=v1

# YooKassa redirect-url, должен совпадать с YK_RETURN_URL в backend .env
YOOKASSA_RETURN_URL=voicenote://payment/success

# 'development' | 'production'. В development включаются Dio request/response logs.
ENV=development
