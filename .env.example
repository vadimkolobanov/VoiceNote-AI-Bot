# ───────────────── Backend env (PRODUCT_PLAN.md §11) ─────────────────
# Скопируй этот файл в `.env` и подставь свои значения.
# `.env` в .gitignore — на git его не публикуем.

# ───── Telegram bot (legacy capture-канал, §16) ─────
TG_BOT_TOKEN=

# ───── JWT (для /api/v1/auth/*) ─────
# Сгенерь так: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# ───── PostgreSQL (`Sekretar` на dev-провайдере) ─────
DB_HOST=
DB_PORT=5432
DB_NAME=Sekretar
DB_USER=
DB_PASSWORD=

# ───── Redis (для rate-limit, опционально — есть InMemory fallback) ─────
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=

# ───── LLM (DeepSeek-V3, primary для facet_extract) ─────
DEEPSEEK_API_KEY=

# ───── STT (Yandex SpeechKit fallback; SaluteSpeech подключим в M5.5) ─────
YANDEX_SPEECHKIT_API_KEY=
YANDEX_SPEECHKIT_FOLDER_ID=

# ───── Firebase (push-уведомления, M7) ─────
# Скачай service account JSON в Firebase Console → положи рядом с проектом
# и укажи путь. Или используй default GOOGLE_APPLICATION_CREDENTIALS.
# (Файл *.json в .gitignore — не уйдёт на git.)

# ───── YooKassa billing (M7) ─────
# 'mock' — без сети, для UX-теста. 'yookassa' — боевой режим (нужны ключи).
YK_MODE=mock
YK_SHOP_ID=
YK_SECRET_KEY=
YK_RETURN_URL=voicenote://payment/success
YK_API_BASE=https://api.yookassa.ru/v3

# ───── Логирование / телеметрия (необязательно) ─────
LOGTAIL_SOURCE_TOKEN=
LOGTAIL_HOST=

# ───── Прочее ─────
ADMIN_TELEGRAM_ID=
NEWS_CHANNEL_URL=
CHAT_URL=
DONATION_URL=
APP_USER_AGENT=VoiceNoteAIBot/1.0 (contact@example.com)
APP_VERSION=dev
